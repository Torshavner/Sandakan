title: Sandakan — AI Agentic RAG System Architecture {
  near: top-center
  shape: text
  style.font-size: 22
  style.bold: true
}

direction: right

# ─── Layer 4: Presentation ────────────────────────────────────────────────────
presentation: Presentation Layer {
  style.fill: "#e3f2fd"

  api: REST API\n(Axum) {
    shape: hexagon
  }

  handlers: Handlers {
    style.fill: "#bbdefb"

    ingest: POST /api/v1/ingest\n(Multipart Upload) {
      shape: rectangle
    }

    ingestRef: POST /api/v1/ingest-reference\n(URL Ingestion) {
      shape: rectangle
    }

    chat: POST /v1/chat/completions\n(OpenAI-compat SSE) {
      shape: rectangle
    }

    query: POST /api/v1/query\n(RAG Query) {
      shape: rectangle
    }

    agent: POST /api/v1/agent/chat\n(Agentic SSE) {
      shape: rectangle
    }

    jobs: GET /api/v1/jobs/:id\n(Job Status) {
      shape: rectangle
    }

    health: GET /health {
      shape: rectangle
    }
  }

  main: main.rs\n(Composition Root) {
    shape: rectangle
  }

  config: Settings\n(Typed Config + APP_* env) {
    shape: rectangle
  }
}

# ─── Layer 3: Infrastructure ──────────────────────────────────────────────────
infrastructure: Infrastructure Layer {
  style.fill: "#fff3e0"

  persistence: Persistence {
    style.fill: "#ffe0b2"

    qdrant: QdrantAdapter\n(gRPC · dense+sparse) {
      shape: cylinder
    }

    pgJob: PgJobRepository\n(sqlx) {
      shape: cylinder
    }

    pgConv: PgConversationRepository\n(sqlx) {
      shape: cylinder
    }

    pgEvalEvent: PgEvalEventRepository\n(sqlx) {
      shape: cylinder
    }

    pgEvalOutbox: PgEvalOutboxRepository\n(sqlx · SKIP LOCKED) {
      shape: cylinder
    }

    pgEvalResult: PgEvalResultRepository\n(sqlx) {
      shape: cylinder
    }
  }

  llm: LLM {
    style.fill: "#ffe0b2"

    streamingClient: StreamingLlmClient\n(reqwest + SSE) {
      shape: cloud
    }

    openaiEmbed: OpenAiEmbedder\n(/v1/embeddings) {
      shape: cloud
    }

    localEmbed: LocalCandleEmbedder\n(CPU Inference) {
      shape: cloud
    }
  }

  audio: Audio {
    style.fill: "#ffe0b2"

    candleWhisper: CandleWhisperEngine\n(Local Whisper) {
      shape: document
    }

    openaiWhisper: OpenAiWhisperEngine\n(API · verbose_json) {
      shape: document
    }

    azureWhisper: AzureWhisperEngine\n(Azure STT) {
      shape: document
    }

    decoder: AudioDecoder\n(Symphonia + Rubato) {
      shape: document
    }
  }

  textProc: Text Processing {
    style.fill: "#ffe0b2"

    fileLoader: CompositeFileLoader\n(PDF · Text · Audio · Video) {
      shape: document
    }

    semanticSplit: SemanticSplitter\n(Token-budget groups) {
      shape: document
    }

    fixedSplit: RecursiveCharacterSplitter\n(Char-based) {
      shape: document
    }

    markdownSplit: MarkdownSemanticSplitter\n(Heading-aware) {
      shape: document
    }

    bm25: Bm25SparseEmbedder\n(TF · FNV-1a hash) {
      shape: document
    }
  }

  tools: Tools {
    style.fill: "#ffe0b2"

    ragSearch: RagSearchAdapter\n(VectorStore query) {
      shape: rectangle
    }

    fsTool: FsToolAdapter\n(read · list · search\nscoped to ./src) {
      shape: rectangle
    }

    webSearch: WebSearchAdapter {
      shape: rectangle
    }

    notification: NotificationAdapter {
      shape: rectangle
    }

    staticRegistry: StaticToolRegistry\n(all tools listed) {
      shape: rectangle
    }

    semanticRegistry: SemanticToolRegistry\n(dynamic via embedding) {
      shape: rectangle
    }
  }

  mcp: MCP Clients {
    style.fill: "#ffe0b2"

    stdio: StdioMcpClient\n(subprocess) {
      shape: rectangle
    }

    sse: SseMcpClient\n(HTTP SSE) {
      shape: rectangle
    }

    composite: CompositeMcpClient\n(fan-out) {
      shape: rectangle
    }
  }

  observability: Observability {
    style.fill: "#ffe0b2"

    tracing: InitTracing\n(OTLP → Tempo) {
      shape: rectangle
    }

    correlationId: CorrelationId\n(request propagation) {
      shape: rectangle
    }

    sanitizer: PromptSanitizer\n(PII redaction) {
      shape: rectangle
    }
  }
}

# ─── Layer 2: Application ─────────────────────────────────────────────────────
application: Application Layer {
  style.fill: "#f3e5f5"

  ports: Ports (Traits) {
    style.fill: "#e1bee7"

    fileLoader: FileLoader {
      shape: diamond
    }

    vectorStore: VectorStore\n(search · search_hybrid\nupsert · upsert_hybrid) {
      shape: diamond
    }

    embedder: Embedder {
      shape: diamond
    }

    sparseEmbedder: SparseEmbedder\n(BM25) {
      shape: diamond
    }

    llmClient: LlmClient {
      shape: diamond
    }

    textSplitter: TextSplitter\n(split · split_segments) {
      shape: diamond
    }

    transcription: TranscriptionEngine\n(→ Vec<TranscriptSegment>) {
      shape: diamond
    }

    jobRepo: JobRepository {
      shape: diamond
    }

    convRepo: ConversationRepository {
      shape: diamond
    }

    evalEventRepo: EvalEventRepository {
      shape: diamond
    }

    evalOutboxRepo: EvalOutboxRepository {
      shape: diamond
    }

    toolRegistry: ToolRegistry {
      shape: diamond
    }

    ragSourceCollector: RagSourceCollector {
      shape: diamond
    }

    mcpClientPort: McpClientPort {
      shape: diamond
    }
  }

  services: Services {
    style.fill: "#e1bee7"

    ingestion: IngestionService\n(Sync · file→vectors) {
      shape: rectangle
    }

    worker: IngestionWorker\n(Async background\nmpsc channel) {
      shape: rectangle
    }

    retrieval: RetrievalService\n(RAG · hybrid search\neval capture) {
      shape: rectangle
    }

    agent: AgentService\n(ReAct loop · critic\nmax_iterations) {
      shape: rectangle
    }

    evalWorker: EvalWorker\n(Background scoring\noutbox polling) {
      shape: rectangle
    }

    evalMetrics: EvalMetrics\n(LLM-as-judge\nfaithfulness) {
      shape: rectangle
    }

    tokenCounter: TokenCounter\n(tiktoken-rs) {
      shape: rectangle
    }
  }
}

# ─── Layer 1: Domain ──────────────────────────────────────────────────────────
domain: Domain Layer {
  style.fill: "#e8f5e9"

  entities: Entities {
    style.fill: "#c8e6c9"

    chunk: Chunk\n(ChunkId · start_time) {
      shape: oval
    }

    document: Document\n(ContentType) {
      shape: oval
    }

    documentMetadata: DocumentMetadata\n(title · source_url\ncontent_type · Arc flyweight) {
      shape: oval
    }

    job: Job\n(JobId · JobStatus) {
      shape: oval
    }

    conversation: Conversation\n(ConversationId) {
      shape: oval
    }

    message: Message\n(MessageRole · tool_call_id) {
      shape: oval
    }

    toolCall: ToolCall\n(id · name · arguments) {
      shape: oval
    }

    transcriptSegment: TranscriptSegment\n(text · start_time · end_time) {
      shape: oval
    }

    evalEvent: EvalEvent\n(query · context · answer\nEvalOperationType) {
      shape: oval
    }

    evalOutbox: EvalOutbox\n(status: pending→done/failed) {
      shape: oval
    }

    evalResult: EvalResult\n(faithfulness score 0–1) {
      shape: oval
    }
  }
}

