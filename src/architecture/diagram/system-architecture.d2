# ─── Data Flows ───────────────────────────────────────────────────────────────
flows: Data Flows {
  near: bottom-left
  style.fill: "#fffef7"

  ingestion: |`
    Ingestion (Write Path):
    Upload -> Job(Queued) -> mpsc -> IngestionWorker
    -> CompositeFileLoader -> TextSplitter(+split_segments for media)
    -> Embedder(dense) + SparseEmbedder(BM25)
    -> VectorStore.upsert_hybrid -> Job(Completed)
    + EvalEvent + EvalOutbox row (if eval.enabled)
  `| {
    shape: text
    style.font-size: 11
  }

  retrieval: |`
    Retrieval (Read Path):
    Query -> Embedder(dense) [+ SparseEmbedder if hybrid]
    -> VectorStore.search [or search_hybrid -> RRF fusion]
    -> Token-budget ranking -> Augment prompt
    -> LlmClient -> SSE stream
    + Fire-and-forget: EvalEvent + EvalOutbox (if eval.enabled)
  `| {
    shape: text
    style.font-size: 11
  }

  agent: |`
    Agentic Loop (ReAct):
    AgentChatRequest -> AgentService
    -> [Reason] LlmClient (tool_choice: auto)
    -> [Act]    ToolRegistry.execute(tool_call)
               -> RagSearchAdapter | FsToolAdapter | WebSearch | MCP
    -> [Observe] append ToolResult to messages
    -> repeat until finish_reason=stop or max_iterations
    -> [Reflect] CriticEvaluator score (completeness, grounding, clarity)
    -> SSE stream progress events to client
  `| {
    shape: text
    style.font-size: 11
  }

  eval: |`
    Eval Background Worker:
    EvalOutbox(pending) -> FOR UPDATE SKIP LOCKED
    -> EvalWorker.process_entry()
    -> EvalMetrics.compute_faithfulness() (LLM-as-judge)
    -> EvalResult persisted -> outbox row -> done/failed
    + structured tracing event: eval.result {score, model}
  `| {
    shape: text
    style.font-size: 11
  }
}

# ─── Tech Stack ───────────────────────────────────────────────────────────────
techStack: Tech Stack {
  near: bottom-right
  style.fill: "#fafafa"

  stack: "tokio · axum · sqlx · qdrant-client · serde · tracing · candle · symphonia · reqwest · tiktoken-rs · fnv · hurl" {
    shape: text
    style.font-size: 11
  }
}
