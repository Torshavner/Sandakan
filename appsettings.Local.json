{
  "server": {
    "host": "127.0.0.1",
    "port": 8080
  },
  "qdrant": {
    "url": "http://localhost:6334",
    "collection_name": "ai-academy-chunks_local",
    "hybrid_search": "true"
  },
  "database": {
    "url": "postgres://sandakan:sandakan@localhost:5432/sandakan",
    "max_connections": 10,
    "run_migrations": true
  },
  "embeddings": {
    "provider": "local",
    "model": "sentence-transformers/all-MiniLM-L6-v2",
    "dimension": 384,
    "chunk_overlap": 50
  },
  "chunking": {
    "max_chunk_size": 512,
    "overlap_tokens": 50,
    "strategy": "semantic"
  },
  "llm": {
    "provider": "lmstudio",
    "api_key": "lm-studio",
    "base_url": "http://localhost:1234/v1",
    "chat_model": "meta-llama-3.1-8b-instruct",
    "max_tokens": 38079,
    "temperature": 0.7,
    "sse_keep_alive_seconds": 15
  },
  "logging": {
    "level": "debug",
    "enable_json": false,
    "enable_udp": true,
    "tempo_endpoint": "http://localhost:4317"
  },
  "storage": {
    "provider": "local",
    "local_path": "./uploads",
    "max_upload_size_bytes": 1073741824
  },
  "extraction": {
    "pdf": {
      "enabled": true,
      "max_file_size_mb": 50,
      "provider": "lm_studio",
      "vlm_model": "qwen3-vl-8b-instruct-mlx@6bit",
      "vlm_base_url": "http://localhost:1234",
      "vlm_api_key": "lm-studio"
    },
    "audio": {
      "enabled": true,
      "max_file_size_mb": 100,
      "whisper_model": "openai/whisper-small.en",
      "provider": "local",
      "asr_corrections": {
        "rog": "RAG",
        "rac": "RAG",
        "agentic rack": "Agentic RAG",
        "agente c rack": "Agentic RAG",
        "hroma": "Chroma",
        "chroma db": "ChromaDB",
        "pinecon": "Pinecone",
        "pine cone": "Pinecone",
        "zlin": "Zilliz",
        "milvus": "Milvus",
        "lang chain": "LangChain",
        "lang graph": "LangGraph",
        "llama index": "LlamaIndex",
        "open ai": "OpenAI",
        "chat gpt": "ChatGPT",
        "gpt 4": "GPT-4",
        "gpt-4 o": "GPT-4o",
        "claude 3": "Claude 3",
        "vector d b": "vector DB",
        "vector store": "vector store",
        "embeddings": "embeddings",
        "fine tuning": "fine-tuning",
        "fine tune": "fine-tune",
        "retrieval augmented generation": "Retrieval-Augmented Generation",
        "retrieval augmented": "retrieval-augmented",
        "hallucination": "hallucination"
      }
    },
    "video": {
      "enabled": true,
      "max_file_size_mb": 500
    }
  },
  "rag": {
    "similarity_threshold": 0.45,
    "max_context_tokens": 3072,
    "top_k": 10,
    "system_prompt": "You are a helpful assistant. Answer the user's question by synthesizing the provided context. The context may come from slides, documents, or structured notes — extract and explain the relevant information even if it is in bullet or table form. Only say you cannot answer if the context is genuinely unrelated to the question.\n\nContext:\n{context}",
    "fallback_message": "I cannot answer this based on the available lecture notes."
  },
  "agent": {
    "enabled": true,
    "system_prompt": "You are a helpful AI assistant with access to tools. Use the right tool for each task:\n\n- When the user asks about documents, slides, lecture notes, or knowledge base content: call rag_search first.\n- When the user asks to search a GitHub repository, find how something is implemented in code, or explore source files: use GitHub tools (search_repositories, search_code, get_file_contents) — do NOT use rag_search for this.\n- When both code and knowledge base context are needed, use both.\n\nDo not answer from memory alone — always use the appropriate tool first, then synthesise the results into a clear answer. Reason step-by-step: think about what information you need, call the appropriate tools, observe the results, and synthesise a final answer. Always cite relevant sources from retrieved content when available.",
    "max_iterations": 10,
    "tool_timeout_secs": 30,
    "tool_fail_fast": false,
    "rag_search_enabled": true,
    "semantic_tools": false,
    "max_tool_results": 5,
    "fs_tools": {
      "root_path": "./src",
      "max_read_bytes": 32768,
      "max_dir_entries": 200
    },
      "mcp_servers": [
      {
        "transport": "stdio",
        "name": "github",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-github"],
        "env": {
          "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
        }
      }
    ]
  }
}
